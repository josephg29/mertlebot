# Copy this file to .env and fill in your real keys.
# Never commit .env to version control.

# Anthropic API key — set this instead of using the in-app UI for production
ANTHROPIC_API_KEY=sk-ant-...

# DeepSeek API key (optional alternative provider)
# DEEPSEEK_API_KEY=sk-your-deepseek-key-here

# Directory where app.db and backups/ will be stored (default: ./data)
DATA_DIR=./data

# Override the full database path directly (takes precedence over DATA_DIR)
# DATABASE_PATH=/mnt/volume/app.db

# Backup retention in days (default: 7)
# BACKUP_RETAIN_DAYS=7

# Server port (default: 3000)
# PORT=3000

# ── Email (password reset) ────────────────────────────────────────────────────
# Provider: smtp | sendgrid | mailgun | console (default: console — logs to stdout)
EMAIL_PROVIDER=console
EMAIL_FROM=Mertle <noreply@example.com>

# SMTP settings (EMAIL_PROVIDER=smtp)
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=user@example.com
# SMTP_PASS=yourpassword

# SendGrid (EMAIL_PROVIDER=sendgrid)
# SENDGRID_API_KEY=SG.xxx

# Mailgun (EMAIL_PROVIDER=mailgun)
# MAILGUN_API_KEY=key-xxx
# MAILGUN_DOMAIN=mg.example.com
# MAILGUN_REGION=us   # or eu

# ── Email verification ────────────────────────────────────────────────────────
# Set to 'true' to block unverified users from /api/generate, /api/clarify, etc.
# REQUIRE_EMAIL_VERIFICATION=false
